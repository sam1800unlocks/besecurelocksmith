---
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';

const businesses = [
  { name: 'The Home Depot',    logo: '/img/businesses/The-Home-Depot.png' },
  { name: 'Lowe’s',      logo: '/img/businesses/Lowes.png' },
  { name: 'McDonald’s',  logo: '/img/businesses/McDonalds.png' },
  { name: 'Outback Steakhouse', logo: '/img/businesses/Outback-Steakhouse.png' },
  { name: 'Publix',            logo: '/img/businesses/Publix.png' },
  { name: 'Walmart',           logo: '/img/businesses/Walmart.png' },
  { name: 'Rural King',        logo: '/img/businesses/Rural-King.png' },
  { name: 'Crunch Fitness',    logo: '/img/businesses/Crunch-Fitness.png' },
  { name: 'Carrabba’s',  logo: '/img/businesses/Carrabbas.png' },
];
---

<Section class="bg-surface">
  <Container>
    <div class="py-12">
      <h3 class="m-0 mb-7 text-2xl font-medium tracking-[-0.4px] text-ink text-center">
        Businesses We&rsquo;ve Had the Pleasure of Working With
      </h3>
      <div class="flex flex-wrap justify-center gap-4">
        {businesses.map(b => (
          <div class="bg-white border border-border rounded-[16px] h-[92px] w-[160px] flex items-center justify-center p-[18px]">
            <img
              src={b.logo}
              alt={b.name}
              loading="lazy"
              class="max-w-full max-h-[46px] object-contain grayscale opacity-[0.62] transition-opacity hover:opacity-100 hover:grayscale-0"
            />
          </div>
        ))}
      </div>
    </div>
  </Container>
</Section>
