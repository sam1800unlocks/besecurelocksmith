---
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';
import { resolveLocation, resolvePhone } from '../../lib/locations';
import { telHref, smsHref, site } from '../../config/site';

const { location = 'main' } = Astro.props;
const phone = resolvePhone(resolveLocation(location));

const phoneIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>';
const textIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>';
const bookIcon = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>';

const methods = [
  { label: 'Call Us',     value: phone,           prompt: 'Talk to a local locksmith now', href: telHref(phone),       icon: phoneIcon, external: false },
  { label: 'Text Us',     value: site.smsPhone,   prompt: 'Send us a quick message',        href: smsHref(site.smsPhone), icon: textIcon,  external: false },
  { label: 'Book Online', value: 'Schedule a visit', prompt: 'Reserve a time that works for you', href: site.bookingUrl,  icon: bookIcon,  external: true },
];
---
<Section class="py-10">
  <Container>
    <div class="max-w-[1180px] mx-auto grid gap-6" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));">
      {methods.map((m) => (
        <a
          href={m.href}
          target={m.external ? '_blank' : undefined}
          rel={m.external ? 'noopener noreferrer' : undefined}
          class="group rounded-[24px] border border-border bg-white p-7 flex flex-col gap-2.5 transition-colors hover:border-primary"
        >
          <span class="w-12 h-12 rounded-full bg-primary/10 text-primary flex items-center justify-center mb-1" set:html={m.icon}></span>
          <span class="text-[12px] font-bold uppercase tracking-[0.6px] text-primary">{m.label}</span>
          <span class="text-[20px] font-bold leading-[1.2] tracking-[-0.3px] text-ink">{m.value}</span>
          <span class="text-[14px] leading-[1.5] text-muted">{m.prompt}</span>
        </a>
      ))}
    </div>
  </Container>
</Section>
