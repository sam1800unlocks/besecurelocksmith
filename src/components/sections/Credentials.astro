---
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';
import Card from '../primitives/Card.astro';

const credentials = [
  { logo: '/img/credentials/ALOA-300wx200h.jpg',                  alt: 'ALOA',                          title: 'ALOA Member',          blurb: 'Associated Locksmiths of America certified.' },
  { logo: '/img/credentials/BNI-logo-300x200-1.png',              alt: 'BNI',                           title: 'BNI Member',            blurb: 'Trusted local business networking community.' },
  { logo: '/img/credentials/1-800-unlocks-300x200-1.png',         alt: '1-800-Unlocks',                 title: '1-800-Unlocks',         blurb: 'Verified member of the national directory.' },
  { logo: '/img/credentials/fair-trade-300x200-1.png',            alt: 'Fair Trade Locksmith Directory', title: 'Fair Trade Locksmith',  blurb: 'Listed in the Fair Trade Locksmith Directory.' },
  { logo: '/img/credentials/Gainesville-Chamber-of-Commerce.png', alt: 'Greater Gainesville Chamber',   title: 'Chamber Member',        blurb: 'Greater Gainesville Chamber of Commerce.' },
];
---

<Section>
  <Container>
    <div class="pt-6 pb-16">
      <h2 class="m-0 mb-8 text-center font-medium tracking-[-0.8px] text-ink" style="font-size:clamp(26px,3.4vw,36px);">
        Trust Our Credentials, Trust Us.
      </h2>
      <div class="grid gap-4" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));">
        {credentials.map(c => (
          <Card class="p-6 flex flex-col items-center text-center gap-3">
            <img
              src={c.logo}
              alt={c.alt}
              loading="lazy"
              class="h-16 w-auto object-contain"
            />
            <span class="text-[18px] font-bold tracking-[-0.2px] text-ink">{c.title}</span>
            <span class="text-[14px] leading-[1.43] text-muted">{c.blurb}</span>
          </Card>
        ))}
      </div>
    </div>
  </Container>
</Section>
