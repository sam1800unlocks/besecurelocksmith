---
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';
import Card from '../primitives/Card.astro';

const credentials = [
  { mark: 'ALOA',  title: 'ALOA Member',          blurb: 'Associated Locksmiths of America certified.' },
  { mark: 'BNI',   title: 'BNI Member',            blurb: 'Trusted local business networking community.' },
  { mark: '1·800', title: '1-800-Unlocks',         blurb: 'Verified member of the national directory.' },
  { mark: 'FT',    title: 'Fair Trade Locksmith',  blurb: 'Listed in the Fair Trade Locksmith Directory.' },
  { mark: 'GG',    title: 'Chamber Member',        blurb: 'Greater Gainesville Chamber of Commerce.' },
];
---

<Section>
  <Container>
    <div class="pt-6 pb-16">
      <h2 class="m-0 mb-8 text-center font-medium tracking-[-0.8px] text-ink" style="font-size:clamp(26px,3.4vw,36px);">
        Trust Our Credentials, Trust Us.
      </h2>
      <div class="grid gap-4" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));">
        {credentials.map(c => (
          <Card class="p-6 flex flex-col items-center text-center gap-3">
            <span class="w-16 h-16 rounded-full bg-surface flex items-center justify-center text-[20px] font-extrabold tracking-[-0.5px] text-ink">
              {c.mark}
            </span>
            <span class="text-[18px] font-bold tracking-[-0.2px] text-ink">{c.title}</span>
            <span class="text-[14px] leading-[1.43] text-muted">{c.blurb}</span>
          </Card>
        ))}
      </div>
    </div>
  </Container>
</Section>
