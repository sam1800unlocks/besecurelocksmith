---
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';

const credentials = [
  { logo: '/img/credentials/ALOA-300wx200h.jpg',                  alt: 'ALOA',                          title: 'ALOA Member',          blurb: 'Associated Locksmiths of America certified.',          href: 'https://www.aloa.org/index.html' },
  { logo: '/img/credentials/BNI-logo-300x200-1.png',              alt: 'BNI',                           title: 'BNI Member',            blurb: 'Trusted local business networking community.',        href: 'https://bniwcf.com/fl-central-west-bni-green-machine-(gainesville)/en-US/memberdetails?encryptedMemberId=qFCDCTJSAOQWqGccpDVGeg%3D%3D&cmsv3=true&name=Brittany++White' },
  { logo: '/img/credentials/1-800-unlocks-300x200-1.png',         alt: '1-800-Unlocks',                 title: '1-800-Unlocks',         blurb: 'Verified member of the national directory.',          href: 'https://1800unlocks.com/locksmith/florida/gainesville/be-secure-locksmith-gainesville/' },
  { logo: '/img/credentials/fair-trade-300x200-1.png',            alt: 'Fair Trade Locksmith Directory', title: 'Fair Trade Locksmith',  blurb: 'Listed in the Fair Trade Locksmith Directory.',        href: 'https://fairtradelocksmiths.com/locksmith/local/be-secure-locksmith-gainesville' },
  { logo: '/img/credentials/Gainesville-Chamber-of-Commerce.png', alt: 'Greater Gainesville Chamber',   title: 'Chamber Member',        blurb: 'Greater Gainesville Chamber of Commerce.',            href: 'https://members.gainesvillechamber.com/list/member/be-secure-locksmith-gainesville-30726' },
];
---

<Section>
  <Container>
    <div class="pt-6 pb-16">
      <h2 class="m-0 mb-8 text-center font-medium tracking-[-0.8px] text-ink" style="font-size:clamp(26px,3.4vw,36px);">
        Trust Our Credentials, Trust Us.
      </h2>
      <div class="grid gap-4" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));" data-stagger>
        {credentials.map(c => (
          <a
            href={c.href}
            target="_blank"
            rel="noopener noreferrer nofollow"
            aria-label={`${c.title} — opens in a new tab`}
            class="group bg-white border border-border rounded-[16px] p-6 flex flex-col items-center text-center gap-3 transition-all duration-200 hover:border-primary hover:-translate-y-0.5 hover:shadow-[0_10px_28px_rgba(10,19,23,0.10)]"
          >
            <img
              src={c.logo}
              alt={c.alt}
              loading="lazy"
              class="h-16 w-auto object-contain"
            />
            <span class="text-[18px] font-bold tracking-[-0.2px] text-ink group-hover:text-primary transition-colors">{c.title}</span>
            <span class="text-[14px] leading-[1.43] text-muted">{c.blurb}</span>
          </a>
        ))}
      </div>
    </div>
  </Container>
</Section>
