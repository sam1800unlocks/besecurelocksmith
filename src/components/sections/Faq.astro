---
import { getCollection } from 'astro:content';
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';

interface FaqItem {
  question: string;
  answer: string;
  order: number;
}

interface Props {
  faqs?: FaqItem[];
  variant?: 'plain' | 'rich';
}

const { faqs, variant = 'plain' } = Astro.props;
const rich = variant === 'rich';
const items = faqs ?? (await getCollection('faqs')).map((e) => e.data);
const sorted = [...items].sort((a, b) => a.order - b.order);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: sorted.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<Section id="faq" class="py-16">
  <Container>
    <div style="max-width:860px;margin:0 auto;">
      <h2
        class="m-0 mb-8 font-medium text-ink"
        style="font-size:clamp(26px,3.4vw,36px);letter-spacing:-0.8px;"
      >
        Be Secure Locksmith FAQs.
      </h2>

      <div class={rich ? 'faq--rich flex flex-col gap-3' : 'flex flex-col gap-3'}>
        {sorted.map((faq, i) => (
          <details
            data-faq
            open={i === 0 ? true : undefined}
            class={rich
              ? 'border border-border border-l-4 border-l-primary rounded-2xl overflow-hidden bg-white transition-all duration-200 hover:shadow-[0_8px_24px_rgba(10,19,23,0.08)] hover:-translate-y-px'
              : 'border border-border rounded-2xl overflow-hidden bg-white'}
          >
            <summary class="flex items-center justify-between gap-4 px-6 py-[22px] cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              {rich ? (
                <span class="flex items-center gap-3 min-w-0">
                  <span class="shrink-0 w-7 h-7 rounded-full bg-primary/10 text-primary text-[13px] font-bold flex items-center justify-center">{i + 1}</span>
                  <span class="text-[18px] font-bold leading-snug text-ink" style="letter-spacing:-0.2px;">{faq.question}</span>
                </span>
              ) : (
                <span
                  class="text-[18px] font-bold leading-snug text-ink"
                  style="letter-spacing:-0.2px;"
                >
                  {faq.question}
                </span>
              )}
              <span
                data-faq-chevron
                class="shrink-0 transition-transform duration-200 [[open]_&]:rotate-180"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#5d6c7b"
                  stroke-width="2.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </span>
            </summary>
            <div
              class={rich ? 'faq-answer px-6 pb-6 text-base leading-relaxed text-muted' : 'px-6 pb-6 text-base leading-relaxed text-muted'}
              style="letter-spacing:-0.16px;"
            >
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </Container>
</Section>

{rich && (
  <style is:global>
    @keyframes faqAnswerIn {
      from { opacity: 0; transform: translateY(-4px); }
      to   { opacity: 1; transform: none; }
    }
    .faq--rich details[open] > .faq-answer { animation: faqAnswerIn 0.22s ease; }
  </style>
)}

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<script>
  import '../scripts/faq.ts';
</script>
