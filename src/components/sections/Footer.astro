---
import { telHref, smsHref, site, serviceAreas } from '../../config/site';
import { offices } from '../../config/offices';
import { resolveLocation, resolveSocials } from '../../lib/locations';
import Container from '../primitives/Container.astro';

const { location = 'main' } = Astro.props;
const socials = resolveSocials(resolveLocation(location));
---

<footer class="border-t border-border bg-white">
  <!-- Service areas (top) — signature gradient band so it stands out -->
  <section class="border-b border-border" style="background:#f4f4f4;">
    <Container>
      <div class="py-12 md:py-14">
        <p class="m-0 mb-2 text-[12px] font-bold uppercase tracking-[1.4px] text-muted">Service Areas</p>
        <h3 class="m-0 mb-6 text-[18px] md:text-[20px] font-bold leading-[1.4] tracking-[-0.2px] text-ink max-w-[860px]">
          We provide car, home, and business locksmith services to these and other areas near Gainesville, FL:
        </h3>
        <div class="flex flex-wrap gap-2.5">
          {serviceAreas.map((a) => (
            <a
              href={a.href}
              class="inline-flex items-center rounded-pill border border-border bg-white px-[14px] py-[7px] text-[13px] font-medium text-ink transition-colors hover:border-primary hover:text-primary"
            >{a.name}, FL</a>
          ))}
          <a
            href="/service-areas/"
            class="inline-flex items-center rounded-pill bg-primary px-[15px] py-[7px] text-[13px] font-bold text-white shadow-[0_2px_10px_rgba(10,19,23,0.12)] transition-transform hover:-translate-y-px"
          >All service areas &#x2192;</a>
        </div>
      </div>
    </Container>
  </section>

  <Container>
    <div class="py-14 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1fr] gap-10">
      <!-- Brand column — wider, leads the row -->
      <div class="max-w-[380px]">
        <img src={site.logo} alt={site.name} class="h-10 mb-4" />
        <p class="m-0 mb-3 text-[18px] font-bold tracking-[-0.2px] text-ink">
          {site.tagline}
        </p>
        <p class="m-0 mb-[14px] text-[14px] leading-[1.5] text-muted">
          Family-operated and serving Gainesville, Ocala and the surrounding communities since 2012 — fast, honest, fully licensed mobile locksmith service.
        </p>
        <p class="m-0 mb-[18px] text-[13px] text-muted">
          License #{site.license} · Liability Insurance #{site.insurance}
        </p>
        <!-- Social icons -->
        <div class="flex flex-wrap gap-2">
          {socials.map((s) => (
            <a
              href={s.href}
              aria-label={s.name}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full border border-border flex items-center justify-center bg-white"
            >
              <img src={s.icon} alt={s.name} class="w-5 h-5 object-contain" />
            </a>
          ))}
        </div>
      </div>

      <!-- Contact column -->
      <div>
        <h5 class="m-0 mb-4 text-[13px] font-bold tracking-[0.6px] uppercase text-primary">Contact</h5>
        <div class="flex flex-col gap-4 text-[14px] text-muted leading-[1.5]">
          {Object.values(offices).map((o) => (
            <div class="flex flex-col gap-[6px]">
              <span class="font-semibold text-ink">{o.label}</span>
              <span>{o.street}<br />{o.cityStateZip}</span>
              <a href={telHref(o.phone)} class="mt-0.5 inline-flex w-fit items-center justify-center rounded-pill bg-call hover:bg-call-hover text-white font-bold text-[14px] px-[18px] py-[9px] transition-colors">{o.phone}</a>
            </div>
          ))}
          <div class="flex flex-col gap-[6px]">
            <a href={smsHref(site.smsPhone)} class="inline-flex w-fit items-center justify-center rounded-pill border border-border bg-white text-ink font-bold text-[14px] px-[18px] py-[9px] hover:border-primary hover:text-primary transition-colors">Text Us</a>
            <span>{site.hours}</span>
          </div>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h5 class="m-0 mb-4 text-[13px] font-bold tracking-[0.6px] uppercase text-primary">Services</h5>
        <div class="flex flex-col gap-2">
          {site.footerServices.map((s) => (
            <a href={s.href} class="text-[14px] text-muted leading-[1.5] hover:text-ink">
              {s.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Payments column -->
      <div>
        <h5 class="m-0 mb-4 text-[13px] font-bold tracking-[0.6px] uppercase text-primary">Payments</h5>
        <div class="flex flex-wrap gap-2 mb-5">
          {site.payments.map((p) => (
            <span class="border border-border rounded-pill px-[14px] py-[7px] text-[13px] font-semibold text-muted">
              {p}
            </span>
          ))}
        </div>
        <p class="m-0 text-[14px] text-ink font-bold">
          We&#x2019;re Hiring!{' '}
          <a href="/employment/" class="text-primary font-bold">
            Apply today &#x2192;
          </a>
        </p>
      </div>
    </div>
  </Container>

  <!-- Bottom bar -->
  <div class="border-t border-border">
    <Container>
      <div class="py-5 flex flex-wrap gap-x-[14px] gap-y-[6px] items-center justify-center text-center">
        <span class="text-[12px] text-muted">© Be Secure Locksmith</span>
        <span class="text-[12px] text-border-2">·</span>
        <a href="/privacy-policy/" class="text-[12px] text-muted hover:text-ink">Privacy Policy</a>
        <span class="text-[12px] text-border-2">·</span>
        <span class="text-[12px] text-muted">{site.agencyCredit}</span>
        <span class="text-[12px] text-border-2">·</span>
        <span class="text-[12px] text-muted">Verified 1-800-Unlocks Member</span>
      </div>
    </Container>
  </div>
</footer>
