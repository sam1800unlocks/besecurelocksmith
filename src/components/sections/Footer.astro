---
import { resolveLocation, resolvePhone } from '../../lib/locations';
import { telHref, smsHref, site } from '../../config/site';
import Container from '../primitives/Container.astro';

const { location = 'main' } = Astro.props;
const loc = resolveLocation(location);
const phone = resolvePhone(loc);
---

<footer class="border-t border-[#dee3e9] bg-white">
  <Container>
    <div
      class="py-14"
      style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:40px;"
    >
      <!-- Brand column — spans full width, max 380px -->
      <div style="grid-column:1/-1;max-width:380px;">
        <img
          src={site.logo}
          alt={site.name}
          class="h-10 mb-4"
        />
        <p class="m-0 mb-3 text-[18px] font-bold tracking-[-0.2px] text-[#0a1317]">
          {site.tagline}
        </p>
        <p class="m-0 mb-[14px] text-[14px] leading-[1.5] text-[#5d6c7b]">
          Family-operated and serving Gainesville, Ocala and the surrounding communities since 2012 — fast, honest, fully licensed mobile locksmith service.
        </p>
        <p class="m-0 text-[13px] text-[#5d6c7b]">
          License #{site.license} · Liability Insurance #{site.insurance}
        </p>
      </div>

      <!-- Contact column -->
      <div>
        <h5 class="m-0 mb-4 text-[13px] font-bold tracking-[0.6px] uppercase text-[#5d6c7b]">Contact</h5>
        <div class="flex flex-col gap-[10px] text-[14px] text-[#5d6c7b] leading-[1.5]">
          <span>
            {loc.nap.street},<br />{loc.nap.city}, {loc.nap.state} {loc.nap.zip}
          </span>
          <a href={telHref(phone)} class="text-[#0a1317] font-semibold">
            Call {phone}
          </a>
          <a href={smsHref(site.smsPhone)} class="text-[#0a1317] font-semibold">
            Text {site.smsPhone}
          </a>
          <span>{loc.hours}</span>
        </div>
        <!-- Social icons -->
        <div class="flex gap-2 mt-[18px]">
          {site.socials.map((s) => (
            <a
              href={s.href}
              aria-label={s.name}
              class="w-9 h-9 rounded-full border border-[#dee3e9] flex items-center justify-center bg-white"
            >
              <img src={s.icon} alt={s.name} class="w-4 h-4 object-contain" />
            </a>
          ))}
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h5 class="m-0 mb-4 text-[13px] font-bold tracking-[0.6px] uppercase text-[#5d6c7b]">Services</h5>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px 18px;">
          {site.footerServices.map((s) => (
            <a href="/services/" class="text-[14px] text-[#5d6c7b] leading-[1.5]">
              {s}
            </a>
          ))}
        </div>
      </div>

      <!-- Payments column -->
      <div>
        <h5 class="m-0 mb-4 text-[13px] font-bold tracking-[0.6px] uppercase text-[#5d6c7b]">Payments</h5>
        <div class="flex flex-wrap gap-2 mb-5">
          {site.payments.map((p) => (
            <span class="border border-[#dee3e9] rounded-[100px] px-[14px] py-[7px] text-[13px] font-semibold text-[#5d6c7b]">
              {p}
            </span>
          ))}
        </div>
        <p class="m-0 text-[14px] text-[#0a1317] font-bold">
          We&#x2019;re Hiring!{' '}
          <a href="/employment/" class="text-[#0064e0] font-bold">
            Apply today &#x2192;
          </a>
        </p>
      </div>
    </div>
  </Container>

  <!-- Bottom bar -->
  <div class="border-t border-[#dee3e9]">
    <Container>
      <div class="py-5 flex flex-wrap gap-x-[14px] gap-y-[6px] items-center justify-center text-center">
        <span class="text-[12px] text-[#5d6c7b]">© Be Secure Locksmith</span>
        <span class="text-[12px] text-[#ced0d4]">·</span>
        <a href="/privacy-policy/" class="text-[12px] text-[#5d6c7b]">Privacy Policy</a>
        <span class="text-[12px] text-[#ced0d4]">·</span>
        <span class="text-[12px] text-[#5d6c7b]">{site.agencyCredit}</span>
        <span class="text-[12px] text-[#ced0d4]">·</span>
        <span class="text-[12px] text-[#5d6c7b]">Verified 1-800-Unlocks Member</span>
      </div>
    </Container>
  </div>
</footer>
