---
import { resolveLocation, resolvePhone } from '../../lib/locations';
import { telHref, site } from '../../config/site';
import Button from '../primitives/Button.astro';
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';
import Badge from '../primitives/Badge.astro';

const { location = 'main' } = Astro.props;
const loc = resolveLocation(location);
const phone = resolvePhone(loc);
const phoneHref = telHref(phone);

const reassurances = ['Upfront pricing', 'Quality parts', 'Same-day service'];
---

<Section id="top" class="py-16 bg-[#f4f4f4]">
  <Container>
    <div class="grid gap-12 items-center" style="grid-template-columns:repeat(auto-fit,minmax(340px,1fr));">

      <!-- Left: copy -->
      <div class="flex flex-col items-start" data-hero-col>

        <!-- Trust badge -->
        <Badge tone="success" class="gap-2 text-[13px] font-bold px-[14px] py-[7px] mb-5 border border-success-2/45">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Family-owned &amp; operated · Since {site.sinceYear}
        </Badge>

        <!-- H1 -->
        <h1 class="m-0 mb-[18px] font-medium leading-[1.12] tracking-[-1.5px] text-ink text-balance"
            style="font-size:clamp(28px,5.4vw,64px);">
          Top Local Locksmith in {loc.city}, FL
        </h1>

        <!-- Subhead -->
        <p class="m-0 mb-8 font-light leading-[1.28] text-secondary text-pretty"
           style="font-size:clamp(20px,2.6vw,28px);max-width:520px;">
          Our lock-solid integrity gives you the peace of mind you deserve.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 mb-6">
          <Button href={phoneHref} variant="call" data-cta-shine>
            {phone}
          </Button>
          <Button href="#services" variant="dark">
            Explore Our Services
          </Button>
        </div>

        <!-- Reassurances -->
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-4 text-sm font-medium text-secondary">
          {reassurances.map((r) => (
            <span class="inline-flex items-center gap-1.5">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1f7a36" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {r}
            </span>
          ))}
        </div>

        <!-- Featured lock brands -->
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 text-sm">
          <span class="text-muted font-medium">Featured Lock Brands:</span>
          {site.brands.map((b) => (
            <span class="text-ink font-bold tracking-[-0.2px]">{b}</span>
          ))}
        </div>

      </div>

      <!-- Right: image -->
      <div class="relative" data-anim="hero-img">
        <picture>
          <source srcset="/img/smart-lock-installation-Be-Secure-Locksmith-1024x768.avif" type="image/avif" />
          <source srcset="/img/smart-lock-installation-Be-Secure-Locksmith-1024x768.webp" type="image/webp" />
          <img
            src="/img/smart-lock-installation-Be-Secure-Locksmith-1024x768.jpeg"
            alt="Be Secure Locksmith technician installing a smart lock"
            fetchpriority="high"
            width="1024"
            height="768"
            class="w-full h-auto object-cover rounded-[32px] block"
            style="aspect-ratio:4/3;"
          />
        </picture>
        <!-- Floating pill -->
        <div class="absolute left-5 bottom-5 bg-white/[0.96] backdrop-blur-sm rounded-[100px] px-[18px] py-[10px] flex items-center gap-[9px] shadow-[0_4px_18px_rgba(10,19,23,0.12)]">
          <span class="w-[9px] h-[9px] rounded-full bg-success-2 inline-block" aria-hidden="true"></span>
          <span class="text-sm font-bold text-ink">Typically on-site in ~30 min</span>
        </div>
      </div>

    </div>
  </Container>
</Section>
