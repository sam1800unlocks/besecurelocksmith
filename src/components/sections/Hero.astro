---
import { resolveLocation, resolvePhone } from '../../lib/locations';
import { telHref, site } from '../../config/site';
import Button from '../primitives/Button.astro';
import Stars from '../primitives/Stars.astro';
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';
import Badge from '../primitives/Badge.astro';

const { location = 'main' } = Astro.props;
const loc = resolveLocation(location);
const phone = resolvePhone(loc);
const phoneHref = telHref(phone);
---

<Section id="top" class="py-16">
  <Container>
    <div class="grid gap-12 items-center" style="grid-template-columns:repeat(auto-fit,minmax(340px,1fr));">

      <!-- Left: copy -->
      <div class="flex flex-col items-start">

        <!-- Trust badge -->
        <Badge tone="success" class="gap-2 text-[13px] font-bold px-[14px] py-[7px] mb-5">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Licensed #{site.license} · Insured · Since {site.sinceYear}
        </Badge>

        <!-- H1 -->
        <h1 class="m-0 mb-[18px] font-medium leading-[1.12] tracking-[-1.5px] text-ink"
            style="font-size:clamp(28px,5.4vw,64px);">
          Top Local Locksmith in {loc.city}, FL
        </h1>

        <!-- Subhead -->
        <p class="m-0 mb-8 font-light leading-[1.28] text-secondary"
           style="font-size:clamp(20px,2.6vw,28px);max-width:520px;">
          Our lock-solid integrity gives you the peace of mind you deserve.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 mb-6">
          <Button href={phoneHref} variant="primary">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Call {phone}
          </Button>
          <Button href="/services/" variant="dark">
            Explore Our Services
          </Button>
        </div>

        <!-- Rating row -->
        <div class="flex items-center gap-[10px] text-sm text-secondary font-medium">
          <Stars count={5} />
          <span class="text-ink font-bold">{site.ratingValue}</span>
          <span>· {Number(site.ratingCount).toLocaleString('en-US')} Google reviews · Family-operated</span>
        </div>

      </div>

      <!-- Right: image -->
      <div class="relative">
        <img
          src="/img/smart-lock-installation-Be-Secure-Locksmith-1024x768.jpeg"
          alt="Be Secure Locksmith technician installing a smart lock"
          fetchpriority="high"
          width="1024"
          height="768"
          class="w-full h-auto object-cover rounded-[32px] block"
          style="aspect-ratio:4/3;"
        />
        <!-- Floating pill -->
        <div class="absolute left-5 bottom-5 bg-white/[0.96] backdrop-blur-sm rounded-[100px] px-[18px] py-[10px] flex items-center gap-[9px] shadow-[0_4px_18px_rgba(10,19,23,0.12)]">
          <span class="w-[9px] h-[9px] rounded-full bg-success-2 inline-block" aria-hidden="true"></span>
          <span class="text-sm font-bold text-ink">Typically on-site in ~30 min</span>
        </div>
      </div>

    </div>
  </Container>
</Section>
