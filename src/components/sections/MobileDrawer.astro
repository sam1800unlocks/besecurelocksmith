---
import { resolveLocation, resolvePhone } from '../../lib/locations';
import { telHref, site, nav as navTabs, serviceMenu, aboutMenu, locationsMenu } from '../../config/site';
import Picture from '../primitives/Picture.astro';

const { location = 'main' } = Astro.props;
const loc = resolveLocation(location);
const phone = resolvePhone(loc);
---
<!-- Mobile Drawer: hidden unless [data-open] is present (toggled by drawer.ts) -->
<div
  data-drawer
  class="fixed inset-0 z-[100] bg-[rgba(10,19,23,0.5)] [display:none] [&[data-open]]:flex"
>
  <!-- Overlay click area -->
  <div data-drawer-close class="absolute inset-0"></div>

  <!-- Panel -->
  <div class="absolute top-0 right-0 bottom-0 w-[min(380px,86vw)] bg-white flex flex-col p-5 overflow-y-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <Picture src={site.logo} alt={site.name} class="h-[34px]" />
      <button
        data-drawer-close
        aria-label="Close"
        class="w-10 h-10 rounded-full border border-border bg-white flex items-center justify-center cursor-pointer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0a1317" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Nav links -->
    <div class="flex flex-col gap-[6px]">
      {navTabs.map((tab) => (
        tab.dropdown ? (
          <details class="group/svc">
            <summary class="flex items-center justify-between text-ink text-[15px] font-semibold px-4 py-3 rounded-lg hover:bg-surface cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              {tab.label}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open/svc:rotate-180" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="flex flex-col gap-3 pl-4 pb-2 pt-1">
              {tab.dropdown === 'services' ? (
                <>
                <a href={tab.href} data-drawer-close class="block px-2 py-[7px] text-[14px] font-semibold text-primary rounded-md hover:bg-surface">View All Services &rarr;</a>
                {serviceMenu.map((grp) => (
                  <div>
                    {grp.href ? (
                      <a href={grp.href} data-drawer-close class="block px-2 py-1 text-[12px] font-bold uppercase tracking-[0.6px] text-primary">{grp.label}</a>
                    ) : (
                      <span class="block px-2 py-1 text-[12px] font-bold uppercase tracking-[0.6px] text-muted-2">{grp.label}</span>
                    )}
                    {grp.items.map((it) => (<a href={it.href} data-drawer-close class="block px-2 py-[7px] text-[14px] text-ink rounded-md hover:bg-surface">{it.label}</a>))}
                  </div>
                ))}
                </>
              ) : (
                (tab.dropdown === 'about' ? aboutMenu : locationsMenu).map((it) => (
                  <a href={it.href} data-drawer-close class="block px-2 py-[7px] text-[14px] text-ink rounded-md hover:bg-surface">{it.label}</a>
                ))
              )}
            </div>
          </details>
        ) : (
          <a
            href={tab.href}
            data-drawer-close
            class="text-ink text-[15px] font-semibold px-4 py-3 rounded-lg hover:bg-surface"
          >
            {tab.label}
          </a>
        )
      ))}
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-col gap-[10px] mt-6">
      <a
        href={telHref(phone)}
        class="bg-call text-white text-[15px] font-bold text-center py-[14px] rounded-[100px]"
      >
        {phone}
      </a>
      <a
        href="https://online-booking.workiz.com/?ac=744610670459142e62f3f47913956e45311c10147d3f5224d2489d7eab57c2a7"
        target="_blank"
        rel="noopener noreferrer"
        data-drawer-close
        class="bg-booking text-white text-[15px] font-bold text-center py-[14px] rounded-[100px]"
      >
        Book Now
      </a>
    </div>
  </div>
</div>
