---
import { getCollection } from 'astro:content';
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';
import Card from '../primitives/Card.astro';
import Stars from '../primitives/Stars.astro';
import { site } from '../../config/site';

interface ReviewItem {
  name: string;
  initial: string;
  color: string;
  time: string;
  quote: string;
  order: number;
}

interface Props {
  reviews?: ReviewItem[];
}

const { reviews } = Astro.props;
const items = reviews ?? (await getCollection('reviews')).map(e => e.data);
const sorted = [...items].sort((a, b) => a.order - b.order);

// Format ratingCount as "2,544" from the raw "2544" in site config
const ratingCount = Number(site.ratingCount).toLocaleString('en-US');
---

<Section id="reviews" class="py-16">
  <Container>

    <!-- Header row: heading + badge left, prev/next right (desktop) -->
    <div class="flex flex-wrap items-end justify-between gap-5 mb-8">
      <div>
        <h2
          class="m-0 mb-3 font-medium tracking-[-0.8px] text-ink"
          style="font-size:clamp(26px,3.4vw,36px);"
        >
          Check Out Our Google Reviews
        </h2>

        <!-- Google rating badge -->
        <div class="inline-flex items-center gap-3 bg-white border border-border rounded-[16px] px-[18px] py-3">
          <img src="/img/google-g-icon.svg" alt="Google" class="w-[26px] h-[26px]" />
          <div class="text-left">
            <div class="text-[14px] font-bold text-ink">Excellent · <span data-countup={site.ratingValue} data-countup-decimals="1">{site.ratingValue}</span></div>
            <div class="text-[12px] text-muted">Based on <span data-countup={site.ratingCount}>{ratingCount}</span> reviews</div>
          </div>
          <Stars />
        </div>
      </div>

      <!-- Prev / Next buttons (desktop only) -->
      <div class="hidden md:flex gap-[10px]">
        <button
          data-reviews-prev
          aria-label="Previous reviews"
          class="w-11 h-11 rounded-full border border-border-2 bg-white cursor-pointer flex items-center justify-center"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0a1317" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <button
          data-reviews-next
          aria-label="Next reviews"
          class="w-11 h-11 rounded-full border border-border-2 bg-white cursor-pointer flex items-center justify-center"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0a1317" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Review track
         No-JS fallback: viewport is overflow-x:auto so it's scrollable.
         With JS (reviews.ts): buttons call scrollBy on the viewport.         -->
    <div class="overflow-x-auto" data-reviews-viewport tabindex="0" role="region" aria-label="Customer reviews">
      <div class="flex gap-4 pb-1" data-reviews-track data-cards>
        {sorted.map((rv) => (
          <Card class="flex-none w-[360px] max-w-[84vw] p-7 flex flex-col gap-[14px]">
            <span data-star-draw class="inline-block overflow-hidden"><Stars /></span>
            <p class="m-0 text-base leading-[1.5] tracking-[-0.16px] text-body flex-1">
              &#x201C;{rv.quote}&#x201D;
            </p>
            <div class="flex items-center gap-3">
              <span
                class="w-10 h-10 rounded-full text-white text-[15px] font-bold flex items-center justify-center flex-shrink-0"
                style={`background:${rv.color};`}
              >
                {rv.initial}
              </span>
              <div>
                <div class="text-[14px] font-bold text-ink">{rv.name}</div>
                <div class="text-[12px] text-muted">{rv.time}</div>
              </div>
              <img src="/img/google-g-icon.svg" alt="Google" class="w-[18px] h-[18px] ml-auto" />
            </div>
          </Card>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-8">
      <a
        href="/testimonials/"
        class="inline-block bg-black text-white text-[14px] font-bold px-[26px] py-[13px] rounded-[100px]"
      >
        See All Google Reviews
      </a>
    </div>

  </Container>
</Section>

<script>import '../scripts/reviews.ts';</script>
