---
import { telHref, site } from '../../config/site';
import { offices } from '../../config/offices';
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';
import Button from '../primitives/Button.astro';

const { location = 'main' } = Astro.props;

const locations = Object.values(offices).map((o) => ({ ...o, hours: site.hours }));
---

<Section class="py-6 pb-16">
  <Container>

    <h3 class="m-0 mb-6 font-medium leading-[1.3] tracking-[-0.4px] text-ink max-w-[760px]"
        style="font-size:24px;">
      Mobile locksmith service across Gainesville &amp; Ocala, FL
    </h3>

    <!-- Both locations — each with its own map -->
    <div class="grid gap-6 items-stretch" style="grid-template-columns:repeat(auto-fit,minmax(320px,1fr));">
      {locations.map((l) => (
        <div class="rounded-[32px] overflow-hidden border border-border bg-white flex flex-col">
          <div class="relative" style="height:260px;">
            <iframe
              title={`Be Secure Locksmith — ${l.label} location`}
              loading="lazy"
              class="w-full h-full border-0 block"
              src={`https://maps.google.com/maps?q=${encodeURIComponent(l.mapQuery)}&t=&z=14&ie=UTF8&iwloc=&output=embed`}
            ></iframe>
            <a
              href={l.gbp}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`View the ${l.label} location on Google`}
              class="absolute inset-0 z-10 flex items-end justify-end p-3"
            >
              <span class="inline-flex items-center gap-1.5 rounded-pill bg-white/95 px-3 py-[7px] text-[12.5px] font-semibold text-ink shadow-[0_2px_12px_rgba(10,19,23,0.20)]">
                View on Google &rarr;
              </span>
            </a>
          </div>
          <div class="flex flex-col flex-1" style="padding:clamp(24px,3vw,36px);">
            <h4 class="m-0 mb-3 font-medium tracking-[-0.4px] text-ink" style="font-size:22px;">
              {l.label}
            </h4>
            <p class="m-0 mb-2 text-base leading-[1.5] text-body">
              {l.street}<br />{l.cityStateZip}
            </p>
            <p class="m-0 mb-6 text-sm text-muted">{l.hours}</p>
            <Button href={telHref(l.phone)} variant="primary" class="self-start mt-auto">
              {l.phone}
            </Button>
          </div>
        </div>
      ))}
    </div>

  </Container>
</Section>
