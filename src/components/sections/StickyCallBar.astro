---
import { resolveLocation, resolvePhone } from '../../lib/locations';
import { telHref } from '../../config/site';

const { location = 'main' } = Astro.props;
const loc = resolveLocation(location);
const phone = resolvePhone(loc);
---

<!-- Sticky Call Bar — mobile-only fixed bottom bar (shown ≤880px) -->
<div
  class="fixed left-0 right-0 bottom-0 z-[60] bg-white border-t border-[#dee3e9] px-[14px] py-[10px] shadow-[0_-4px_18px_rgba(10,19,23,0.08)]
         max-[880px]:flex hidden items-center justify-between gap-[10px]"
>
  <div class="flex flex-col leading-[1.2]">
    <span class="text-[13px] font-bold text-[#0a1317]">Locked out?</span>
    <span class="text-[12px] text-[#5d6c7b]">Free assessment · ~30 min</span>
  </div>
  <div class="flex gap-2">
    <a
      href={telHref(phone)}
      class="bg-call text-white text-[14px] font-bold px-[22px] py-3 rounded-[100px]"
    >
      {phone}
    </a>
    <a
      href="https://online-booking.workiz.com/?ac=744610670459142e62f3f47913956e45311c10147d3f5224d2489d7eab57c2a7"
      target="_blank"
      rel="noopener noreferrer"
      class="bg-booking text-white text-[14px] font-bold px-[22px] py-3 rounded-[100px]"
    >
      Book
    </a>
  </div>
</div>

<!-- Spacer so mobile content isn't hidden behind the fixed bar -->
<div class="max-[880px]:block hidden h-[68px] w-full"></div>
