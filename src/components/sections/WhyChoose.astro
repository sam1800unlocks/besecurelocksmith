---
import Section from '../primitives/Section.astro';
import Container from '../primitives/Container.astro';
import Button from '../primitives/Button.astro';

const reassurance = [
  '15+ years of experience — done right the first time.',
  'Local, family-operated, and customer-obsessed.',
  'Free security assessment on every visit.',
  'Transparent pricing — no hidden fees, no surprise charges.',
];
---

<Section>
  <Container>
    <div class="grid gap-12 items-center" style="grid-template-columns:repeat(auto-fit,minmax(360px,1fr));padding:64px 0;">

      <!-- Left: copy -->
      <div>
        <h2 class="m-0 mb-[18px] font-medium leading-[1.2] tracking-[-0.8px] text-ink"
            style="font-size:clamp(28px,3.6vw,36px);">
          Why Choose Be Secure Locksmith?
        </h2>
        <p class="m-0 mb-7 text-base leading-[1.5] tracking-[-0.16px] text-secondary" style="max-width:520px;">
          A local, family-operated team that treats your security like our own — fast, transparent, and done right the first time.
        </p>

        <!-- Reassurance bullets -->
        <div class="flex flex-col gap-4 mb-[30px]">
          {reassurance.map((r) => (
            <div class="flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-success-bg flex items-center justify-center mt-[1px]">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#31a24c" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
              <span class="text-base leading-[1.5] tracking-[-0.16px] text-body">{r}</span>
            </div>
          ))}
        </div>

        <Button href="https://online-booking.workiz.com/?ac=744610670459142e62f3f47913956e45311c10147d3f5224d2489d7eab57c2a7" variant="booking" target="_blank" rel="noopener noreferrer">Book Now</Button>
      </div>

      <!-- Right: YouTube facade — loads the ~500KB player only on click -->
      <div class="rounded-[32px] overflow-hidden bg-black relative" style="box-shadow:0 1px 0 #dee3e9;aspect-ratio:16/9;">
        <button type="button" data-yt="HIdYUZ33DO0" aria-label="Play video: Why Choose Be Secure Locksmith" class="group absolute inset-0 w-full h-full cursor-pointer border-0 p-0 block bg-black">
          <img src="/img/why-video-poster.webp" alt="Why Choose Be Secure Locksmith" width="1280" height="720" loading="lazy" class="w-full h-full object-cover block" />
          <span class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
            <span class="w-[68px] h-[48px] rounded-[14px] bg-[#ff0000]/85 group-hover:bg-[#ff0000] transition-colors flex items-center justify-center">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </span>
        </button>
      </div>

    </div>
  </Container>
</Section>

<script>
  // Click-to-load YouTube: swap the facade for the real player only on demand.
  document.querySelectorAll('[data-yt]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-yt');
      const f = document.createElement('iframe');
      f.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      f.title = 'Why Choose Be Secure Locksmith';
      f.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      f.allowFullscreen = true;
      f.className = 'w-full h-full border-0 block';
      btn.replaceWith(f);
    }, { once: true });
  });
</script>
