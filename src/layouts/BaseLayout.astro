---
import '../styles/tokens.css';
// Self-hosted font (same-origin, no render-blocking Google Fonts request).
import '@fontsource-variable/figtree';
// Preload the primary (latin) subset so it's fetched immediately, minimizing FOUT.
import figtreeLatin from '@fontsource-variable/figtree/files/figtree-latin-wght-normal.woff2';
import { resolveLocation, resolvePhone } from '../lib/locations';
import { site } from '../config/site';
import { organizationNode } from '../lib/schema';

interface Props {
  title: string;
  description?: string;
  location?: string;
  ogType?: string;
  ogImage?: string;
  robots?: string;
  schema?: 'org-home' | 'org-lean' | 'none';
}

const {
  title,
  description = '',
  location = 'main',
  ogType = 'website',
  ogImage = '/img/og-default.jpg',
  robots,
  schema = 'none',
} = Astro.props;
const loc = resolveLocation(location);
const phone = resolvePhone(loc);

const siteBase = Astro.site?.href ?? 'https://besecurelocksmith.com/';
const path = Astro.url?.pathname ?? '/';
const canonical = new URL(path, siteBase).href;
const ogImageUrl = ogImage ? new URL(ogImage, siteBase).href : undefined;
// Only advertise 1200x630 for our known default OG image; page-supplied
// images may differ in size, so we omit width/height for those.
const ogIsDefault = ogImage === '/img/og-default.jpg';

const orgSchema = schema === 'org-home' ? organizationNode({ homepage: true })
  : schema === 'org-lean' ? organizationNode({ homepage: false })
  : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {robots && <meta name="robots" content={robots} />}
  <link rel="canonical" href={canonical} />

  <!-- Preload the primary font subset to cut FOUT / font-swap shift -->
  <link rel="preload" href={figtreeLatin} as="font" type="font/woff2" crossorigin="anonymous" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <!-- Open Graph / Twitter -->
  <meta property="og:site_name" content={site.name} />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
  {ogImageUrl && ogIsDefault && <meta property="og:image:width" content="1200" />}
  {ogImageUrl && ogIsDefault && <meta property="og:image:height" content="630" />}
  {ogImageUrl && <meta property="og:image:alt" content={title} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

  {orgSchema &&<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />}
  <slot name="head" />
</head>
<body><slot /></body>
</html>
