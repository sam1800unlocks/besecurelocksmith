---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PromoBar from '../../components/sections/PromoBar.astro';
import NavBar from '../../components/sections/NavBar.astro';
import TrustStrip from '../../components/sections/TrustStrip.astro';
import Credentials from '../../components/sections/Credentials.astro';
import Reviews from '../../components/sections/Reviews.astro';
import Footer from '../../components/sections/Footer.astro';
import StickyCallBar from '../../components/sections/StickyCallBar.astro';
import Section from '../../components/primitives/Section.astro';
import Container from '../../components/primitives/Container.astro';
import Button from '../../components/primitives/Button.astro';
import about from '../../data/about.json';
import { site, telHref } from '../../config/site';
import { resolveLocation, resolvePhone } from '../../lib/locations';

const location = 'main';
const phone = resolvePhone(resolveLocation(location));

const title = 'About Our Gainesville, FL Locksmith Team - Local Pros';
const description = "Meet the team behind Gainesville's most-reviewed locksmith. Licensed, mobile, and rated 4.9 stars by 1,300+ local clients. See why neighbors trust us today.";
const pageUrl = 'https://besecurelocksmith.com/about/';

const joe = about.team.find((t) => t.name === 'Joe');
const team = about.team.filter((t) => t.name !== 'Joe');

const breadcrumbJsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://besecurelocksmith.com/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: pageUrl },
  ],
};
const aboutJsonLd = {
  '@context': 'https://schema.org', '@type': 'AboutPage', name: 'About Be Secure Locksmith', url: pageUrl,
};
---
<BaseLayout title={title} description={description} location={location}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(aboutJsonLd)} />
  </Fragment>
  <PromoBar location={location} />
  <NavBar location={location} />
  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden text-white" style="background:linear-gradient(160deg,#0e4a8f 0%,#0b2f5e 42%,#0a1830 100%);">
      <div class="absolute inset-0 opacity-[0.09]" style="background-image:radial-gradient(circle at 1px 1px,#ffffff 1px,transparent 0);background-size:22px 22px;"></div>
      <div class="absolute -top-28 -right-20 w-[540px] h-[540px] rounded-full pointer-events-none" style="background:radial-gradient(circle,rgba(56,150,255,0.60),transparent 70%);"></div>
      <Container>
        <div class="relative max-w-[1180px] mx-auto py-14 md:py-20">
          <nav aria-label="Breadcrumb" class="mb-5 flex flex-wrap items-center gap-2 text-[13px] text-white/70">
            <a href="/" class="hover:text-white">Home</a>
            <span aria-hidden="true">/</span>
            <span class="text-white">About</span>
          </nav>
          <h1 class="m-0 mb-4 font-medium text-white max-w-[820px]" style="font-size:clamp(32px,5.2vw,56px);line-height:1.08;letter-spacing:-1.2px;">
            About Be Secure Locksmith
          </h1>
          <p class="m-0 mb-7 text-[18px] leading-[1.4] text-white/80 max-w-[680px]">
            Gainesville and Ocala's most-reviewed local locksmith — licensed, mobile, and family-operated since 2012.
          </p>
          <div class="flex flex-wrap gap-3">
            <Button href={telHref(phone)} variant="call">{phone}</Button>
            <Button href={site.bookingUrl} variant="booking" target="_blank" rel="noopener noreferrer">Book Now</Button>
          </div>
        </div>
      </Container>
    </section>

    <TrustStrip />

    <!-- OUR MISSION -->
    <Section class="py-12 md:py-16">
      <Container>
        <div class="max-w-[1180px] mx-auto grid gap-10 items-start" style="grid-template-columns:repeat(auto-fit,minmax(300px,1fr));">
          <div class="max-w-[680px]">
            <h2 class="m-0 text-ink font-medium tracking-[-0.6px]" style="font-size:clamp(26px,3.4vw,34px);line-height:1.2;">Our Mission</h2>
            <div class="mt-3 mb-6 h-1 w-12 rounded-full bg-primary"></div>
            {about.mission.map((p) => <p class="m-0 mb-4 text-[16px] leading-[1.65] text-secondary">{p}</p>)}
          </div>
          {joe && (
            <div class="justify-self-center sm:justify-self-end w-full max-w-[320px] rounded-[24px] border border-border bg-white overflow-hidden" style="box-shadow:0 12px 34px rgba(10,19,23,0.10);">
              <div class="aspect-square overflow-hidden bg-surface">
                <img src={joe.photo} alt={`${joe.name}, ${joe.role}`} width="320" height="320" class="w-full h-full object-cover block" />
              </div>
              <div class="p-5 text-center">
                <p class="m-0 text-[19px] font-bold text-ink">{joe.name}</p>
                <p class="m-0 text-[14px] text-primary font-semibold">{joe.role}</p>
              </div>
            </div>
          )}
        </div>
      </Container>
    </Section>

    <!-- TEAM -->
    <Section class="pb-12 md:pb-16">
      <Container>
        <div class="max-w-[1180px] mx-auto">
          <h2 class="m-0 mb-8 text-ink font-medium tracking-[-0.6px]" style="font-size:clamp(26px,3.4vw,34px);line-height:1.2;">Meet the Be Secure Locksmith Team</h2>
          <div class="grid gap-6" style="grid-template-columns:repeat(auto-fill,minmax(180px,1fr));">
            {team.map((m) => (
              <div class="rounded-[20px] border border-border bg-white overflow-hidden text-center">
                <div class="aspect-square overflow-hidden bg-surface">
                  <img src={m.photo} alt={`${m.name}, ${m.role}`} loading="lazy" width="240" height="240" class="w-full h-full object-cover block" />
                </div>
                <div class="p-4">
                  <p class="m-0 text-[16px] font-bold text-ink leading-tight">{m.name}</p>
                  <p class="m-0 mt-0.5 text-[13px] text-muted leading-tight">{m.role}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </Section>

    <Credentials />
    <Reviews />

    <!-- CTA -->
    <Section class="pb-16 md:pb-20">
      <Container>
        <div class="max-w-[1180px] mx-auto rounded-[24px] text-white relative overflow-hidden" style="background:linear-gradient(150deg,#0e4a8f 0%,#0b2f5e 60%,#0a1830 100%);">
          <div class="absolute -top-24 -right-16 w-[360px] h-[360px] rounded-full pointer-events-none" style="background:radial-gradient(circle,rgba(56,150,255,0.45),transparent 70%);"></div>
          <div class="relative p-8 md:p-12 flex flex-col items-start gap-5">
            <h2 class="m-0 font-medium tracking-[-0.4px] max-w-[640px]" style="font-size:clamp(24px,3.4vw,34px);line-height:1.15;">Work with a team your neighbors trust</h2>
            <p class="m-0 text-[17px] leading-[1.55] text-white/80 max-w-[640px]">Licensed, insured, and family-operated since 2012. Call now or book your mobile locksmith service online.</p>
            <div class="flex flex-wrap gap-3">
              <Button href={telHref(phone)} variant="call">{phone}</Button>
              <Button href={site.bookingUrl} variant="booking" target="_blank" rel="noopener noreferrer">Book Now</Button>
            </div>
          </div>
        </div>
      </Container>
    </Section>
  </main>
  <Footer location={location} />
  <StickyCallBar location={location} />
</BaseLayout>
