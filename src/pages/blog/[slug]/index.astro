---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PromoBar from '../../../components/sections/PromoBar.astro';
import NavBar from '../../../components/sections/NavBar.astro';
import BlogCard from '../../../components/sections/BlogCard.astro';
import CtaCard from '../../../components/sections/CtaCard.astro';
import Footer from '../../../components/sections/Footer.astro';
import Section from '../../../components/primitives/Section.astro';
import Container from '../../../components/primitives/Container.astro';

export async function getStaticPaths() {
  const all = (await getCollection('blog')).map((e) => e.data);
  // Build a page only for posts that have migrated body content.
  return all
    .filter((p) => Array.isArray(p.body) && p.body.length > 0)
    .map((p) => ({ params: { slug: p.slug }, props: { post: p, all } }));
}

const { post, all } = Astro.props;
const location = 'main';

const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const [y, m, d] = post.date.split('-').map(Number);
const displayDate = (y && m && d) ? `${MONTHS[m - 1]} ${d}, ${y}` : post.date;

const words = (post.body ?? []).join(' ').replace(/<[^>]+>/g, ' ').split(/\s+/).filter(Boolean).length;
const readTime = Math.max(1, Math.round(words / 200));

const related = all
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => {
    const ca = a.category === post.category ? 0 : 1;
    const cb = b.category === post.category ? 0 : 1;
    return ca !== cb ? ca - cb : (a.date < b.date ? 1 : -1);
  })
  .slice(0, 3);

const pageUrl = `https://besecurelocksmith.com/blog/${post.slug}/`;
const ctaBody = `Need a key made, a lockout solved, or new locks? Be Secure Locksmith is your local, mobile locksmith — <a href="/contact-us/">contact us today</a> or call now for fast, licensed service.`;

const blogPostingJsonLd = {
  '@context': 'https://schema.org', '@type': 'BlogPosting',
  headline: post.title, datePublished: post.date,
  author: { '@type': 'Person', name: post.author ?? 'Be Secure Locksmith' },
  image: post.heroImage ? new URL(post.heroImage, 'https://besecurelocksmith.com').href : undefined,
  mainEntityOfPage: pageUrl, url: pageUrl,
  publisher: { '@type': 'Organization', name: 'Be Secure Locksmith' },
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://besecurelocksmith.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://besecurelocksmith.com/blog/' },
    { '@type': 'ListItem', position: 3, name: post.title, item: pageUrl },
  ],
};
---
<BaseLayout title={post.metaTitle ?? post.title} description={post.metaDescription ?? post.excerpt} location={location}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogPostingJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <PromoBar location={location} />
  <NavBar location={location} />
  <main>
    <article>
      <!-- Post header -->
      <Container>
        <div class="max-w-[760px] mx-auto pt-10 md:pt-14">
          <nav aria-label="Breadcrumb" class="mb-5 flex flex-wrap items-center gap-2 text-[13px] text-muted">
            <a href="/" class="hover:text-primary">Home</a>
            <span aria-hidden="true">/</span>
            <a href="/blog/" class="hover:text-primary">Blog</a>
            <span aria-hidden="true">/</span>
            <span class="text-ink">{post.category}</span>
          </nav>
          <span class="inline-flex rounded-pill bg-primary/10 px-[12px] py-[5px] text-[12px] font-semibold text-primary">{post.category}</span>
          <h1 class="m-0 mt-4 mb-3 font-medium text-ink" style="font-size:clamp(28px,4.4vw,44px);line-height:1.12;letter-spacing:-1px;">
            {post.title}
          </h1>
          <p class="m-0 text-[14px] text-muted">
            By <span class="font-semibold text-ink">{post.author}</span> · {displayDate} · {readTime} min read
          </p>
        </div>
      </Container>

      {post.heroImage && (
        <Container>
          <div class="max-w-[760px] mx-auto mt-7">
            <img src={post.heroImage} alt={post.title} width="760" height="430" class="w-full h-auto rounded-[20px] border border-border block" style="box-shadow:0 12px 34px rgba(10,19,23,0.12);" />
          </div>
        </Container>
      )}

      <!-- Body -->
      <Container>
        <div class="post-prose max-w-[760px] mx-auto py-10 md:py-12">
          {(post.body ?? []).map((block) => <Fragment set:html={block} />)}
        </div>
      </Container>

      <!-- End CTA -->
      <Container>
        <div class="max-w-[760px] mx-auto pb-4">
          <CtaCard location={location} heading="Talk to a local locksmith today" body={ctaBody} />
        </div>
      </Container>
    </article>

    <!-- Related posts -->
    {related.length > 0 && (
      <Section class="py-12 md:py-16">
        <Container>
          <div class="max-w-[1180px] mx-auto">
            <h2 class="m-0 mb-6 text-ink font-medium tracking-[-0.4px]" style="font-size:clamp(22px,3vw,28px);">More from the blog</h2>
            <div class="grid gap-6" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr));">
              {related.map((p) => <BlogCard post={p} />)}
            </div>
            <a href="/blog/" class="inline-flex items-center gap-1.5 mt-8 text-[15px] font-semibold text-primary hover:text-primary-hover">&larr; Back to all posts</a>
          </div>
        </Container>
      </Section>
    )}
  </main>
  <Footer location={location} />
</BaseLayout>

<style is:global>
  .post-prose p { margin: 0 0 1.15rem; font-size: 17px; line-height: 1.7; color: var(--color-secondary); }
  .post-prose h3 { margin: 2rem 0 0.6rem; font-size: 22px; font-weight: 700; letter-spacing: -0.3px; color: var(--color-ink); }
  .post-prose ul, .post-prose ol { margin: 0 0 1.15rem; padding-left: 1.3rem; }
  .post-prose ul { list-style: disc; }
  .post-prose ol { list-style: decimal; }
  .post-prose li { margin-bottom: 0.45rem; font-size: 17px; line-height: 1.6; color: var(--color-secondary); }
  .post-prose a { color: #0064e0; text-decoration: underline; text-underline-offset: 2px; }
  .post-prose a:hover { color: #0457cb; }
  .post-prose figure { margin: 1.5rem 0; }
  .post-prose figure img { display: block; width: 100%; height: auto; border-radius: 16px; }
  .post-prose figcaption { margin-top: 0.5rem; font-size: 13.5px; line-height: 1.5; color: var(--color-muted); font-style: italic; }
</style>
