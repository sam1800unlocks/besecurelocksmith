---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PromoBar from '../../../../components/sections/PromoBar.astro';
import NavBar from '../../../../components/sections/NavBar.astro';
import BlogList from '../../../../components/sections/BlogList.astro';
import Footer from '../../../../components/sections/Footer.astro';
import StickyCallBar from '../../../../components/sections/StickyCallBar.astro';
import { allPosts, categoriesOf, catSlug } from '../../../../lib/blog';

export async function getStaticPaths() {
  const posts = await allPosts();
  const categories = categoriesOf(posts);
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: { cat, categories, posts: posts.filter((p) => catSlug(p.category) === cat.slug) },
  }));
}

const { cat, categories, posts } = Astro.props;
const location = 'main';
const intro = `Locksmith tips and guides on ${cat.name.toLowerCase()} from Be Secure Locksmith — serving Gainesville, Ocala, and surrounding areas.`;
---
<BaseLayout
  title={`${cat.name} Articles | Be Secure Locksmith Blog`}
  description={intro}
  location={location}
  robots="noindex, follow"
>
  <PromoBar location={location} />
  <NavBar location={location} />
  <BlogList
    heading={cat.name}
    intro={intro}
    posts={posts}
    categories={categories}
    activeSlug={cat.slug}
    categoryName={cat.name}
  />
  <Footer location={location} />
  <StickyCallBar location={location} />
</BaseLayout>
