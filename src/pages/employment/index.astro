---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PromoBar from '../../components/sections/PromoBar.astro';
import NavBar from '../../components/sections/NavBar.astro';
import TrustStrip from '../../components/sections/TrustStrip.astro';
import Footer from '../../components/sections/Footer.astro';
import StickyCallBar from '../../components/sections/StickyCallBar.astro';
import Container from '../../components/primitives/Container.astro';
import Button from '../../components/primitives/Button.astro';
import { site, telHref } from '../../config/site';
import { resolveLocation, resolvePhone } from '../../lib/locations';

const location = 'main';
const phone = resolvePhone(resolveLocation(location));

const title = 'Locksmith Jobs Gainesville, FL - Join Our Local Team';
const description = 'Looking for locksmith jobs in Gainesville, FL? Join a licensed, growing mobile team serving Gainesville and Ocala. See current openings and apply with us today.';
const pageUrl = 'https://besecurelocksmith.com/employment/';

const positions = [
  {
    title: 'Ocala, FL Locksmith Technician',
    summary: 'We’re seeking a mechanically inclined individual with sales experience for a new Locksmith position in Ocala.',
    requirements: [
      'Experience preferred but not required.',
      'Must be able to pass a background check and have a clean driving record.',
    ],
    closing: 'Apply today to be a part of the Be Secure Locksmith team that provides reliable, mobile locksmith services across Gainesville, Ocala, Lake City, The Villages, and other surrounding areas.',
  },
];

const checkSvg = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#31a24c" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://besecurelocksmith.com/' },
    { '@type': 'ListItem', position: 2, name: 'Employment', item: pageUrl },
  ],
};
const jobJsonLd = {
  '@context': 'https://schema.org', '@type': 'JobPosting',
  title: 'Locksmith Technician', employmentType: 'FULL_TIME',
  description: 'We are seeking a mechanically inclined individual with sales experience for a new Locksmith position in Ocala, FL. Experience preferred but not required. Must pass a background check and have a clean driving record.',
  hiringOrganization: { '@type': 'Organization', name: site.name, sameAs: 'https://besecurelocksmith.com/' },
  jobLocation: { '@type': 'Place', address: { '@type': 'PostalAddress', addressLocality: 'Ocala', addressRegion: 'FL', addressCountry: 'US' } },
  directApply: true,
};
---
<BaseLayout title={title} description={description} location={location}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(jobJsonLd)} />
  </Fragment>
  <PromoBar location={location} />
  <NavBar location={location} />
  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden text-white" style="background:linear-gradient(160deg,#0e4a8f 0%,#0b2f5e 42%,#0a1830 100%);">
      <div class="absolute inset-0 opacity-[0.09]" style="background-image:radial-gradient(circle at 1px 1px,#ffffff 1px,transparent 0);background-size:22px 22px;"></div>
      <div class="absolute -top-28 -right-20 w-[540px] h-[540px] rounded-full pointer-events-none" style="background:radial-gradient(circle,rgba(56,150,255,0.60),transparent 70%);"></div>
      <Container>
        <div class="relative max-w-[1180px] mx-auto py-14 md:py-20">
          <nav aria-label="Breadcrumb" class="mb-5 flex flex-wrap items-center gap-2 text-[13px] text-white/70">
            <a href="/" class="hover:text-white">Home</a>
            <span aria-hidden="true">/</span>
            <span class="text-white">Employment</span>
          </nav>
          <h1 class="m-0 mb-4 font-medium text-white max-w-[820px]" style="font-size:clamp(32px,5.2vw,56px);line-height:1.08;letter-spacing:-1.2px;">
            Employment Opportunities
          </h1>
          <p class="m-0 mb-7 text-[18px] leading-[1.4] text-white/80 max-w-[680px]">
            Join a licensed, family-operated, and growing mobile locksmith team serving Gainesville, Ocala, and North Central FL.
          </p>
          <div class="flex flex-wrap gap-3">
            <Button href={telHref(phone)} variant="call">{phone}</Button>
            <Button href="/contact-us/" variant="booking">Contact Us</Button>
          </div>
        </div>
      </Container>
    </section>

    <TrustStrip />

    <article class="article-body">
      <Container>
        <div class="max-w-[1180px] mx-auto py-12 md:py-16">
          <div class="grid gap-8 lg:gap-10 lg:grid-cols-[1fr_460px] items-start">
            <!-- LEFT: openings + info -->
            <div>
              <h2 class="m-0 text-ink font-medium tracking-[-0.6px]" style="font-size:clamp(26px,3.4vw,34px);line-height:1.2;">Now Hiring For These Positions at Be Secure Locksmith</h2>
              <div class="mt-3 mb-5 h-1 w-12 rounded-full bg-primary"></div>
              <p class="m-0 mb-8 text-[16px] leading-[1.65] text-secondary">We&rsquo;re always looking for dependable, customer-focused people to grow with us. Review our current openings and apply with the form on this page.</p>

              <div class="grid gap-6">
                {positions.map((job) => (
                  <div class="rounded-[24px] border border-border bg-white p-7 md:p-9" style="box-shadow:0 12px 34px rgba(10,19,23,0.06);">
                    <span class="inline-flex items-center rounded-pill bg-success-bg text-success-2 text-[12px] font-bold uppercase tracking-[0.6px] px-[12px] py-[6px]">Now Hiring</span>
                    <h3 class="mt-4 mb-3 text-ink font-bold text-[22px] tracking-[-0.3px]">{job.title}</h3>
                    <p class="m-0 mb-5 text-[16px] leading-[1.65] text-secondary">{job.summary}</p>
                    <ul class="m-0 p-0 list-none flex flex-col gap-3 mb-6">
                      {job.requirements.map((r) => (
                        <li class="flex items-start gap-3 text-[16px] leading-[1.5] text-body">
                          <span class="mt-[3px] shrink-0 w-6 h-6 rounded-full bg-success-bg flex items-center justify-center" set:html={checkSvg}></span>
                          <span>{r}</span>
                        </li>
                      ))}
                    </ul>
                    <p class="m-0 text-[16px] leading-[1.65] text-secondary">{job.closing}</p>
                  </div>
                ))}
              </div>

              <figure class="m-0 mt-8">
                <img src="/img/employment/be-secure-team.jpg" alt="The Be Secure Locksmith team" width="640" height="480" loading="lazy" class="block w-full h-auto rounded-[20px] border border-border" style="box-shadow:0 12px 34px rgba(10,19,23,0.12);" />
                <figcaption class="mt-[10px] text-[13.5px] leading-[1.5] text-muted italic">Apply today to be a part of the Be Secure Locksmith team that provides reliable, mobile locksmith services across Gainesville, Ocala, Lake City, The Villages, and other surrounding areas.</figcaption>
              </figure>
            </div>

            <!-- RIGHT: application form -->
            <section id="apply" class="rounded-[24px] border border-border p-6 sm:p-8 lg:sticky lg:top-24" style="background:#eef4ff;">
            <h2 class="m-0 text-ink font-medium tracking-[-0.4px]" style="font-size:clamp(22px,3vw,28px);line-height:1.2;">Apply Today</h2>
            <div class="mt-3 mb-4 h-1 w-12 rounded-full bg-primary"></div>
            <p class="m-0 mb-6 text-[16px] leading-[1.6] text-secondary max-w-[680px]">Fill out the form below and upload your resume. Prefer to talk first? Call us at <a href={telHref(phone)} class="text-primary font-semibold">{phone}</a>.</p>

            <form action="/api/employment" method="POST" enctype="multipart/form-data" data-employment-form class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink">First name
                <input type="text" name="firstName" autocomplete="given-name" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal" />
              </label>
              <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink">Last name
                <input type="text" name="lastName" autocomplete="family-name" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal" />
              </label>
              <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink">Email <span class="text-alert">*</span>
                <input type="email" name="email" required autocomplete="email" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal" />
              </label>
              <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink">Phone <span class="text-alert">*</span>
                <input type="tel" name="phone" required autocomplete="tel" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal" />
              </label>
              <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink sm:col-span-2">Street address
                <input type="text" name="street" autocomplete="address-line1" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal" />
              </label>
              <div class="sm:col-span-2 grid grid-cols-2 sm:grid-cols-3 gap-4">
                <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink">City
                  <input type="text" name="city" autocomplete="address-level2" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal" />
                </label>
                <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink">State
                  <input type="text" name="state" autocomplete="address-level1" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal" />
                </label>
                <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink">ZIP
                  <input type="text" name="zip" inputmode="numeric" autocomplete="postal-code" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal" />
                </label>
              </div>
              <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink sm:col-span-2">Position
                <select name="position" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal">
                  <option>Locksmith Technician</option>
                  <option>Other / General Application</option>
                </select>
              </label>
              <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink sm:col-span-2">Upload your resume <span class="text-alert">*</span>
                <input type="file" name="resume" required accept=".pdf,.doc,.docx,.rtf,.txt,application/pdf" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal file:mr-4 file:rounded-full file:border-0 file:bg-primary file:text-white file:px-4 file:py-2 file:text-[13px] file:font-semibold file:cursor-pointer" />
                <span class="text-[12.5px] font-normal text-muted">PDF or Word document, up to 10 MB.</span>
              </label>
              <label class="flex flex-col gap-1.5 text-[14px] font-semibold text-ink sm:col-span-2">What else do you want us to know about you?
                <textarea name="message" rows="4" class="rounded-[12px] border border-border bg-white px-4 py-3 text-[15px] font-normal resize-y"></textarea>
              </label>
              <input type="text" name="bsl_hp" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" />
              <div class="sm:col-span-2 flex flex-wrap items-center gap-4">
                <button type="submit" class="inline-flex items-center gap-2 text-[15px] font-bold px-[30px] py-[15px] rounded-[100px] bg-primary text-white cursor-pointer">Submit Application</button>
                <p data-employment-status class="m-0 text-[14px] text-muted"></p>
              </div>
            </form>
            </section>
          </div>
        </div>
      </Container>
    </article>
  </main>
  <Footer location={location} />
  <StickyCallBar location={location} />

  <script>
    const form = document.querySelector('[data-employment-form]') as HTMLFormElement | null;
    const status = document.querySelector('[data-employment-status]');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (status) { status.textContent = 'Sending…'; status.className = 'm-0 text-[14px] text-muted'; }
      try {
        const res = await fetch('/api/employment', { method: 'POST', body: new FormData(form!), headers: { 'x-requested-with': 'fetch' } });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          form!.reset();
          if (status) { status.textContent = 'Thanks! We received your application and will be in touch.'; status.className = 'm-0 text-[14px] text-success-2 font-semibold'; }
        } else {
          const msg = data.error || (data.errors && Object.values(data.errors)[0]) || 'Something went wrong. Please call 352-706-5295.';
          if (status) { status.textContent = msg as string; status.className = 'm-0 text-[14px] text-alert font-semibold'; }
        }
      } catch {
        if (status) { status.textContent = 'Network error. Please call 352-706-5295 or email us your resume.'; status.className = 'm-0 text-[14px] text-alert font-semibold'; }
      }
    });
  </script>
</BaseLayout>
