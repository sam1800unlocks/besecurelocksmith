---
import BaseLayout from '../layouts/BaseLayout.astro';
import PromoBar from '../components/sections/PromoBar.astro';
import NavBar from '../components/sections/NavBar.astro';
import Hero from '../components/sections/Hero.astro';
import TrustStrip from '../components/sections/TrustStrip.astro';
import AsSeenIn from '../components/sections/AsSeenIn.astro';
import WhyChoose from '../components/sections/WhyChoose.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import PropertyManagement from '../components/sections/PropertyManagement.astro';
import LogoWall from '../components/sections/LogoWall.astro';
import ConversionBand from '../components/sections/ConversionBand.astro';
import Reviews from '../components/sections/Reviews.astro';
import OfficesBand from '../components/sections/OfficesBand.astro';
import Credentials from '../components/sections/Credentials.astro';
import BusinessesWorkedWith from '../components/sections/BusinessesWorkedWith.astro';
import Faq from '../components/sections/Faq.astro';
import ContactForm from '../components/sections/ContactForm.astro';
import Footer from '../components/sections/Footer.astro';
const location = 'main';
---
<BaseLayout title="Top Local Locksmith in Gainesville & Ocala, FL | Be Secure Locksmith" description="Licensed & insured mobile locksmith serving Gainesville, Ocala & surrounding areas since 2012." location={location} schema="org-home">
  <Fragment slot="head">
    <!-- Enable entrance reveals only when JS is on AND motion is allowed. A
         failsafe removes the gate if reveal.ts never runs, so content is never
         left hidden. Pre-hidden states are structural CSS (no JS-added classes),
         so there's no flash. -->
    <script is:inline>
      (function () {
        var d = document.documentElement;
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        d.classList.add('reveal-js');
        setTimeout(function () { if (!d.classList.contains('reveal-ready')) d.classList.remove('reveal-js'); }, 2500);
      })();
    </script>
    <style is:global>
      /* ===== Entrance reveals (lightweight GSAP replacement) — gated by .reveal-js ===== */
      /* Hero: staggered column + gently-scaling image (revealed on load) */
      .reveal-js [data-hero-col] > * { opacity: 0; transform: translateY(14px); transition: opacity .55s ease-out, transform .55s ease-out; transition-delay: calc(var(--i, 0) * 70ms + 50ms); }
      .reveal-js [data-hero-col].is-visible > * { opacity: 1; transform: none; }
      .reveal-js [data-anim="hero-img"] { opacity: 0; transform: scale(1.04); transition: opacity .8s ease-out, transform .8s ease-out; }
      .reveal-js [data-anim="hero-img"].is-visible { opacity: 1; transform: none; }

      /* Content sections fade up as a block — EXCEPT sections whose children animate */
      .reveal-js main > :not(#top):not(:has([data-stagger])):not(:has([data-cards])) {
        opacity: 0; transform: translateY(24px);
        transition: opacity .6s cubic-bezier(.16,1,.3,1), transform .6s cubic-bezier(.16,1,.3,1);
      }
      .reveal-js main > :not(#top):not(:has([data-stagger])):not(:has([data-cards])).is-visible { opacity: 1; transform: none; }

      /* Stagger containers: children rise / slide in sequence */
      .reveal-js [data-stagger] > * { opacity: 0; transform: translateY(16px); transition: opacity .5s ease-out, transform .5s ease-out; transition-delay: calc(var(--i, 0) * 70ms); }
      .reveal-js [data-cards] > * { opacity: 0; transform: translateX(24px); transition: opacity .5s ease-out, transform .5s ease-out; transition-delay: calc(var(--i, 0) * 70ms); }
      .reveal-js [data-stagger].is-visible > *,
      .reveal-js [data-cards].is-visible > * { opacity: 1; transform: none; }

      /* Reviews: star clip-reveal */
      .reveal-js [data-star-draw] { clip-path: inset(0 100% 0 0); transition: clip-path .6s ease-out; }
      .reveal-js [data-star-draw].is-visible { clip-path: inset(0 0 0 0); }

      /* Hero CTA: one-time shine sweep + gentle pulse */
      [data-cta-shine] { position: relative; overflow: hidden; }
      [data-cta-shine].shine::after { content: ''; position: absolute; inset: 0; pointer-events: none; border-radius: inherit; background: linear-gradient(105deg, transparent 35%, rgba(255,255,255,.3) 50%, transparent 65%); transform: translateX(-100%); animation: cta-shine .7s ease-in-out forwards; }
      @keyframes cta-shine { to { transform: translateX(100%); } }
      [data-cta-shine].shine { animation: cta-pulse .5s ease-out .1s; }
      @keyframes cta-pulse { 30% { transform: scale(1.03); } 100% { transform: scale(1); } }
    </style>
  </Fragment>
  <PromoBar location={location} />
  <NavBar location={location} />
  <main>
    <Hero location={location} />
    <TrustStrip />
    <AsSeenIn />
    <WhyChoose />
    <ServicesGrid />
    <PropertyManagement />
    <LogoWall />
    <ConversionBand location={location} />
    <Reviews />
    <OfficesBand heading="Visit Our Gainesville & Ocala Offices" subheading="Two licensed, insured mobile locksmith offices serving North Central Florida since 2012." />
    <Credentials />
    <BusinessesWorkedWith />
    <Faq variant="rich" />
    <ContactForm />
  </main>
  <Footer location={location} />

  <script>
    import '../components/scripts/reveal.ts';
  </script>
</BaseLayout>
