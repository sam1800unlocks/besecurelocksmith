---
import BaseLayout from '../layouts/BaseLayout.astro';
import PromoBar from '../components/sections/PromoBar.astro';
import NavBar from '../components/sections/NavBar.astro';
import Hero from '../components/sections/Hero.astro';
import TrustStrip from '../components/sections/TrustStrip.astro';
import AsSeenIn from '../components/sections/AsSeenIn.astro';
import WhyChoose from '../components/sections/WhyChoose.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import PropertyManagement from '../components/sections/PropertyManagement.astro';
import LogoWall from '../components/sections/LogoWall.astro';
import ConversionBand from '../components/sections/ConversionBand.astro';
import Reviews from '../components/sections/Reviews.astro';
import OfficesBand from '../components/sections/OfficesBand.astro';
import Credentials from '../components/sections/Credentials.astro';
import BusinessesWorkedWith from '../components/sections/BusinessesWorkedWith.astro';
import Faq from '../components/sections/Faq.astro';
import ServiceAreas from '../components/sections/ServiceAreas.astro';
import ContactForm from '../components/sections/ContactForm.astro';
import Footer from '../components/sections/Footer.astro';
const location = 'main';
---
<BaseLayout title="Top Local Locksmith in Gainesville & Ocala, FL | Be Secure Locksmith" description="Licensed & insured mobile locksmith serving Gainesville, Ocala & surrounding areas since 2012." location={location} schema="org-home">
  <Fragment slot="head">
    <!-- Pre-hide hero for a flash-free GSAP reveal — only when JS is on AND motion is allowed. -->
    <script is:inline>
      (function () {
        var d = document.documentElement;
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        d.classList.add('gsap-anim');
        // Failsafe: reveal even if the animation script never runs.
        setTimeout(function () { d.classList.remove('gsap-anim'); }, 1600);
      })();
    </script>
    <style is:global>
      .gsap-anim [data-hero-col] > *,
      .gsap-anim [data-anim="hero-img"] { opacity: 0; }
    </style>
  </Fragment>
  <PromoBar location={location} />
  <NavBar location={location} />
  <Hero location={location} />
  <TrustStrip />
  <AsSeenIn />
  <WhyChoose />
  <ServicesGrid />
  <PropertyManagement />
  <LogoWall />
  <ConversionBand location={location} />
  <Reviews />
  <OfficesBand heading="Visit Our Gainesville & Ocala Offices" subheading="Two licensed, insured mobile locksmith offices serving North Central Florida since 2012." />
  <Credentials />
  <BusinessesWorkedWith />
  <Faq variant="rich" />
  <ServiceAreas location={location} />
  <ContactForm />
  <Footer location={location} />

  <script>
    import '../components/scripts/home-anim.ts';
  </script>
</BaseLayout>
